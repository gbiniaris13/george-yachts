# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
public/videos/yacht-cruising-new-original.mp4

# Claude Code working trees (embedded git repos) — never commit
.claude/worktrees/

# Lead lists / scraped contacts — NEVER commit to a public repo
leads/
*.csv
!public/**/*.csv

# Accidental macOS duplicate files (" 2.ext")
* 2.jsx
* 2.js
* 2.png
* 2.jpg
* 2.jpeg
* 2.svg

# Internal outreach docs / scripts that should not be public
docs/outreach-bot-guide-*.md
scripts/DOMINGO-OMKAR-INSTRUCTIONS.md
scripts/OUTREACH-SETUP.md
scripts/outreach-automation.gs
