{
  "crons": [
    {
      "path": "/api/cron/health-check",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/daily-summary",
      "schedule": "0 19 * * *"
    },
    {
      "path": "/api/cron/inquiry-reminder",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/link-audit",
      "schedule": "0 8 * * 1"
    },
    {
      "path": "/api/cron/weekly-newsletter",
      "schedule": "0 7 * * 1"
    },
    {
      "path": "/api/cron/cleanup-expired-drafts",
      "schedule": "0 23 * * *"
    },
    {
      "path": "/api/cron/newsletter-health",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/newsletter-daily-digest",
      "schedule": "0 16 * * *"
    },
    {
      "path": "/api/cron/newsletter-flush-queue",
      "schedule": "30 0 * * *"
    },
    {
      "path": "/api/cron/newsletter-bridge-auto",
      "schedule": "0 6 * * 4"
    },
    {
      "path": "/api/cron/newsletter-wake-auto",
      "schedule": "0 6 15 * *"
    },
    {
      "path": "/api/cron/newsletter-compass-auto",
      "schedule": "0 6 1 * *"
    },
    {
      "path": "/api/cron/newsletter-reengage-followup",
      "schedule": "0 2 * * *"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains; preload"
        },
        {
          "key": "X-DNS-Prefetch-Control",
          "value": "on"
        }
      ]
    },
    {
      "source": "/api/contact",
      "headers": [
        {
          "key": "Access-Control-Allow-Credentials",
          "value": "true"
        },
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "GET,DELETE,POST,OPTIONS"
        },
        {
          "key": "Access-Control-Allow-Headers",
          "value": "X-CSRF-Token, X-Requested-With, Accept, Accept-Version, Content-Length, Content-MD5, Content-Type, Date, X-Api-Version"
        }
      ]
    }
  ]
}
